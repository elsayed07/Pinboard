# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=pinboard
POSTGRES_USER=pinboard
POSTGRES_PASSWORD=pinboard
DATABASE_URL=postgres://pinboard:pinboard@db:5432/pinboard

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Media / Storage ──────────────────────────────────────────────────────────
MEDIA_URL=/media/
# Production S3 (required when DJANGO_SETTINGS_MODULE=config.settings.production):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# OAuth — Google
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# OAuth — GitHub
SOCIAL_AUTH_GITHUB_KEY=
SOCIAL_AUTH_GITHUB_SECRET=

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@pinboard.app

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATELIMIT_USE_CACHE=default

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@pinboard.app

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_IPS=127.0.0.1
